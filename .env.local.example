# Neon Auth — https://neon.com/docs/auth/overview
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Neon Postgres (via Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require

# Vercel Blob (ECG file storage — set on Fly; optional locally for api-fly)
BLOB_READ_WRITE_TOKEN=

# MSG91 WhatsApp
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_CARDIOLOGIST_PHONE=+919000000001
MSG91_TEMPLATE_ID_CARDIOLOGIST=your_template_id_cardiologist
MSG91_TEMPLATE_ID_HEALTH_WORKER=your_template_id_health_worker

# App
NEXT_PUBLIC_APP_URL=https://hridlink.com

# Fly API (local api-fly) — AgentMail optional email alongside MSG91
# AGENTMAIL_API_KEY=
# AGENTMAIL_DOMAIN=agentmail.to
# AGENTMAIL_INBOX_USERNAME=noreply
# NOTIFY_CARDIOLOGIST_EMAIL=
