# Neon Auth — https://neon.com/docs/auth/overview
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Supabase (PostgreSQL via Prisma)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# MSG91 WhatsApp
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_CARDIOLOGIST_PHONE=+919000000001
MSG91_TEMPLATE_ID_CARDIOLOGIST=your_template_id_cardiologist
MSG91_TEMPLATE_ID_HEALTH_WORKER=your_template_id_health_worker

# App
NEXT_PUBLIC_APP_URL=https://hridlink.com
