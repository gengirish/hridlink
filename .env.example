# Copy to .env and fill in values. Never commit .env.

# Fly.io API — required for production builds. Local: http://127.0.0.1:8080 with `npm run dev:stack`
# Vercel: https://hridlink-api.fly.dev (no trailing slash). No duplicate /api routes on Next.
API_UPSTREAM_URL=http://127.0.0.1:8080

# Neon: pooled URL from the Neon dashboard (Connection string → pooled)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Neon: direct URL for Prisma migrations (Connection string → direct, no "-pooler")
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Neon Auth (managed Better Auth) — Project → Branch → Auth → Configuration
# @see https://neon.com/docs/auth/overview
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
MSG91_AUTH_KEY=
MSG91_CARDIOLOGIST_PHONE=
MSG91_TEMPLATE_ID_CARDIOLOGIST=
MSG91_TEMPLATE_ID_HEALTH_WORKER=
NEXT_PUBLIC_APP_URL=http://localhost:3000
